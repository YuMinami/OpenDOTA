<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <!-- 注意：Spring Boot 4.0 尚未正式发布，由于选型的要求，这里引用一个示例版本标识。
         如果在真实环境中运行 `mvn clean install` 找不到依赖，请将其临时降级为 Spring Boot 3.4.x -->
    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>4.0.0-SNAPSHOT</version>
        <relativePath/> <!-- lookup parent from repository -->
    </parent>

    <groupId>com.opendota</groupId>
    <artifactId>opendota-server</artifactId>
    <version>1.0.0-SNAPSHOT</version>
    <packaging>pom</packaging>
    <name>opendota-server</name>
    <description>OpenDOTA 车云通讯诊断平台</description>

    <modules>
        <module>opendota-common</module>
        <module>opendota-mqtt</module>
        <module>opendota-odx</module>
        <module>opendota-diag</module>
        <module>opendota-admin</module>
        <module>opendota-app</module>
    </modules>

    <properties>
        <!-- 强制使用 Java 25 -->
        <java.version>25</java.version>
        <maven.compiler.source>25</maven.compiler.source>
        <maven.compiler.target>25</maven.compiler.target>
        <maven.compiler.enablePreview>true</maven.compiler.enablePreview> <!-- 为 Java最新特性开启预览支持 -->
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        
        <!-- 第三方依赖版本 -->
        <paho.mqtt.version>1.2.5</paho.mqtt.version>
        <springdoc.version>2.5.0</springdoc.version>
    </properties>

    <dependencyManagement>
        <dependencies>
            <!-- Eclipse Paho MQTT 客户端 -->
            <dependency>
                <groupId>org.eclipse.paho</groupId>
                <artifactId>org.eclipse.paho.client.mqttv3</artifactId>
                <version>${paho.mqtt.version}</version>
            </dependency>

            <!-- SpringDoc OpenAPI -->
            <dependency>
                <groupId>org.springdoc</groupId>
                <artifactId>springdoc-openapi-starter-webmvc-ui</artifactId>
                <version>${springdoc.version}</version>
            </dependency>

            <!-- 内部模块依赖隔离 -->
            <dependency>
                <groupId>com.opendota</groupId>
                <artifactId>opendota-common</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.opendota</groupId>
                <artifactId>opendota-mqtt</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.opendota</groupId>
                <artifactId>opendota-odx</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.opendota</groupId>
                <artifactId>opendota-diag</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.opendota</groupId>
                <artifactId>opendota-admin</artifactId>
                <version>${project.version}</version>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <dependencies>
        <!-- 全局通用依赖 -->
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <optional>true</optional>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-logging</artifactId>
        </dependency>
        <!-- Jackson/FastJSON 等基础依赖也可以放这 -->
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <!-- Java 25 编译插件配置 -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <configuration>
                    <source>${java.version}</source>
                    <target>${java.version}</target>
                    <compilerArgs>
                        <!-- 启用预览特性 -->
                        <arg>--enable-preview</arg>
                        <!-- 允许提取方法名参数 -->
                        <arg>-parameters</arg>
                    </compilerArgs>
                </configuration>
            </plugin>
        </plugins>
    </build>

</project>
